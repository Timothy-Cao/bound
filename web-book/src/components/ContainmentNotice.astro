---
interface Props {
  section?: string;
  documentDescription?: string;
}
const {
  section = '§7.2(c)',
  documentDescription = 'this file',
} = Astro.props;
---

<aside class="containment-box" role="alert">
  <div class="containment-tag">[ CONTAINMENT PROTOCOL ENGAGED ]</div>
  <p>
    {documentDescription} cannot be displayed.
  </p>
  <p>
    Stimulus Containment Protocol {section} has determined that the
    content of this file presents an unacceptable risk to viewing
    parties.
  </p>
  <p class="final-line">
    This determination cannot be appealed.
  </p>
</aside>

<style>
  .containment-tag {
    font-weight: 500;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }
  .containment-box p {
    margin-bottom: 1rem;
  }
  .containment-box .final-line {
    margin-bottom: 0;
    margin-top: 1.5rem;
    opacity: 0.85;
  }
</style>
