---
interface Props {
  src: string;
  label: string;
  note?: string;
  duration?: string;
}
const { src, label, note, duration } = Astro.props;
---

<figure class="audio-row not-prose">
  <button type="button" class="audio-play" aria-label={`Play: ${label}`} data-src={src}>▶</button>
  <figcaption class="audio-caption">
    <div class="audio-label">[AUDIO] {label}</div>
    {note && <div class="audio-note">{note}</div>}
    {duration && <div class="audio-duration">{duration}</div>}
  </figcaption>
</figure>

<style>
  .audio-caption {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .audio-label { font-weight: 500; }
  .audio-note { opacity: 0.85; }
  .audio-duration { opacity: 0.7; font-size: 0.75rem; }
</style>

<script is:inline>
  document.addEventListener('click', function (e) {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;
    if (!target.classList.contains('audio-play')) return;
    const src = target.getAttribute('data-src');
    if (!src) return;

    // simple play/stop. each button manages its own audio element.
    let audio = target._audio;
    if (!audio) {
      audio = new Audio(src);
      audio.addEventListener('ended', function () {
        target.textContent = '▶';
      });
      target._audio = audio;
    }
    if (audio.paused) {
      audio.currentTime = 0;
      audio.play().catch(function () { /* ignore */ });
      target.textContent = '■';
    } else {
      audio.pause();
      target.textContent = '▶';
    }
  });
</script>
