---
interface Props {
  src: string;
  label: string;
  note?: string;
  duration?: string;
}
const { src, label, note, duration } = Astro.props;
const playLabel = `Play: ${label}`;
const pauseLabel = `Pause: ${label}`;
---

<figure class="audio-row not-prose">
  <button
    type="button"
    class="audio-play"
    aria-label={playLabel}
    data-src={src}
    data-label-play={playLabel}
    data-label-pause={pauseLabel}
  >▶</button>
  <figcaption class="audio-caption">
    <div class="audio-label">[AUDIO] {label}</div>
    {note && <div class="audio-note">{note}</div>}
    {duration && <div class="audio-duration" aria-label={`Duration ${duration}`}>{duration}</div>}
  </figcaption>
</figure>

<style>
  .audio-caption {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .audio-label { font-weight: 500; }
  .audio-note { opacity: 0.85; }
  .audio-duration { opacity: 0.7; font-size: 0.75rem; }
</style>
