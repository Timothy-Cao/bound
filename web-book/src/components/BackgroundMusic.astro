---
interface Props {
  tracks: string[];
  narration?: string;
  narrationLabel?: string;
}
const { tracks, narration, narrationLabel = 'NARRATION' } = Astro.props;
const hasAudio = tracks.length > 0 || narration;
---

{hasAudio && (
  <div class="audio-panel" data-tracks={JSON.stringify(tracks)} data-narration={narration || ''} data-narration-label={narrationLabel}>
    <button type="button" class="audio-panel-tab mono-block" aria-label="Audio controls" aria-expanded="false">
      ♪
    </button>
    <div class="audio-panel-drawer" aria-hidden="true">
      {tracks.length > 0 && (
        <div class="audio-control">
          <div class="audio-control-row">
            <button type="button" class="audio-btn music-btn" aria-label="Toggle OST">▶</button>
            <span class="audio-control-label">OST</span>
          </div>
          <input type="range" class="audio-slider music-vol" min="0" max="100" value="25" aria-label="OST volume" />
        </div>
      )}
      {narration && (
        <div class="audio-control">
          <div class="audio-control-row">
            <button type="button" class="audio-btn narration-btn" aria-label={`Toggle ${narrationLabel.toLowerCase()}`}>▶</button>
            <span class="audio-control-label">{narrationLabel}</span>
          </div>
          <input type="range" class="audio-slider narration-vol" min="0" max="100" value="50" aria-label={`${narrationLabel} volume`} />
        </div>
      )}
    </div>
  </div>
)}

<script>
  // Music and speech singletons are coordinated through global helpers
  // attached by BaseLayout. See BaseLayout.astro for the contract:
  //   W.__archiveSetMusic(audio, onStop)   — claim music slot
  //   W.__archiveClearMusic(audio)         — release music slot
  //   W.__archiveSetSpeech(audio, onStop)  — claim speech slot
  //   W.__archiveClearSpeech(audio)        — release speech slot
  //
  // Music and speech can overlap each other. Each kind is a singleton.
  // Inline audio artifacts (Audio.astro) share the speech slot with narration.

  // Kill in-progress audio when navigating away (view transitions).
  document.addEventListener('astro:before-swap', () => {
    const W = window as any;
    const a = W.__archiveAudio;
    if (!a) return;
    if (a.music) {
      try { a.music.pause(); a.music.src = ''; } catch (e) { /* ignore */ }
      if (a.musicOnStop) { try { a.musicOnStop(); } catch (e) { /* ignore */ } }
      a.music = null;
      a.musicOnStop = null;
    }
    if (a.speech) {
      try { a.speech.pause(); a.speech.src = ''; } catch (e) { /* ignore */ }
      if (a.speechOnStop) { try { a.speechOnStop(); } catch (e) { /* ignore */ } }
      a.speech = null;
      a.speechOnStop = null;
    }
  });

  document.addEventListener('astro:page-load', () => {
    const panel = document.querySelector('.audio-panel') as HTMLElement | null;
    if (!panel) return;

    const W = window as any;
    const tab = panel.querySelector('.audio-panel-tab') as HTMLButtonElement;
    const drawer = panel.querySelector('.audio-panel-drawer') as HTMLElement;
    const tracks: string[] = JSON.parse(panel.dataset.tracks || '[]');
    const narrationSrc = panel.dataset.narration || '';
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Drawer toggle
    let drawerOpen = false;
    function setDrawer(open: boolean) {
      drawerOpen = open;
      drawer.setAttribute('aria-hidden', String(!drawerOpen));
      tab.setAttribute('aria-expanded', String(drawerOpen));
      panel.classList.toggle('is-open', drawerOpen);
    }
    tab.addEventListener('click', () => setDrawer(!drawerOpen));

    if (!localStorage.getItem('archive_audio_seen')) {
      setDrawer(true);
      localStorage.setItem('archive_audio_seen', '1');
    }

    // Local UI state (per page-load); the actual audio elements live in the
    // global slots and are owned by the page until navigation.
    let musicPlaying = false;
    let speechPlaying = false;

    function updateTabPulse() {
      if (musicPlaying || speechPlaying) tab.classList.add('is-playing');
      else tab.classList.remove('is-playing');
    }

    // Shared AudioContext so volume works on iOS (where HTMLAudioElement.volume
    // is read-only). We route each <audio> through a GainNode.
    let audioCtx: AudioContext | null = null;
    function getCtx(): AudioContext | null {
      try {
        if (!audioCtx) {
          const Ctx = (window as any).AudioContext || (window as any).webkitAudioContext;
          if (!Ctx) return null;
          audioCtx = new Ctx();
        }
        if (audioCtx && audioCtx.state === 'suspended') {
          audioCtx.resume().catch(() => { /* ignore */ });
        }
        return audioCtx;
      } catch (e) {
        return null;
      }
    }

    function wireGain(audio: HTMLAudioElement): GainNode | null {
      const ctx = getCtx();
      if (!ctx) return null;
      try {
        const src = ctx.createMediaElementSource(audio);
        const gain = ctx.createGain();
        src.connect(gain).connect(ctx.destination);
        return gain;
      } catch (e) {
        return null;
      }
    }

    // --- Music ---
    const musicBtn = panel.querySelector('.music-btn') as HTMLButtonElement | null;
    const musicVol = panel.querySelector('.music-vol') as HTMLInputElement | null;
    let musicIndex = 0;
    let musicAudio: HTMLAudioElement | null = null;
    let musicGain: GainNode | null = null;

    function musicVolume(sliderVal: number) { return (sliderVal / 100) * 0.5; }

    function applyMusicVolume(sv: number) {
      const v = musicVolume(sv);
      if (musicGain) musicGain.gain.value = v;
      if (musicAudio) {
        try { musicAudio.volume = v; } catch (e) { /* iOS: read-only */ }
      }
    }

    function createMusic() {
      const audio = new Audio(tracks[musicIndex]);
      const saved = localStorage.getItem('archive_music_vol');
      const sv = saved ? parseInt(saved) : 25;
      musicAudio = audio;
      musicGain = wireGain(audio);
      applyMusicVolume(sv);
      if (musicVol) musicVol.value = String(sv);

      // When one track ends, advance to the next in the chapter's playlist.
      audio.addEventListener('ended', () => {
        if (W.__archiveAudio.music !== audio) return; // we lost the slot
        musicIndex = (musicIndex + 1) % tracks.length;
        audio.src = tracks[musicIndex];
        audio.play().catch(() => { /* ignore */ });
      });

      audio.addEventListener('error', () => {
        musicPlaying = false;
        if (musicBtn) musicBtn.textContent = '▶';
        updateTabPulse();
        W.__archiveClearMusic(audio);
      });

      return audio;
    }

    function resetMusicUI() {
      musicPlaying = false;
      if (musicBtn) musicBtn.textContent = '▶';
      updateTabPulse();
    }

    function playMusic() {
      if (!musicAudio) createMusic();
      // Claim the music slot. This pauses any previously playing music
      // (almost always: none, since previous page navigation cleared it).
      W.__archiveSetMusic(musicAudio!, resetMusicUI);
      musicAudio!.play().then(() => {
        musicPlaying = true;
        if (musicBtn) musicBtn.textContent = '⏸';
        updateTabPulse();
      }).catch(() => { /* user-gesture not yet granted, etc. */ });
    }

    function pauseMusic() {
      if (musicAudio) {
        musicAudio.pause();
        resetMusicUI();
      }
    }

    musicBtn?.addEventListener('click', () => {
      if (musicPlaying) pauseMusic(); else playMusic();
    });

    musicVol?.addEventListener('input', () => {
      const v = parseInt(musicVol.value);
      applyMusicVolume(v);
      localStorage.setItem('archive_music_vol', String(v));
    });

    if (tracks.length > 0 && !reducedMotion) {
      const startOnInteraction = () => {
        if (!musicPlaying) playMusic();
        document.removeEventListener('click', startOnInteraction);
        document.removeEventListener('keydown', startOnInteraction);
        document.removeEventListener('scroll', startOnInteraction);
      };
      document.addEventListener('click', startOnInteraction);
      document.addEventListener('keydown', startOnInteraction);
      document.addEventListener('scroll', startOnInteraction);
    }

    // --- Narration (shares the speech slot with inline audio artifacts) ---
    const narrBtn = panel.querySelector('.narration-btn') as HTMLButtonElement | null;
    const narrVol = panel.querySelector('.narration-vol') as HTMLInputElement | null;
    let narrationAudio: HTMLAudioElement | null = null;
    let narrationGain: GainNode | null = null;

    function applyNarrationVolume(sv: number) {
      const v = sv / 100;
      if (narrationGain) narrationGain.gain.value = v;
      if (narrationAudio) {
        try { narrationAudio.volume = v; } catch (e) { /* iOS: read-only */ }
      }
    }

    function resetNarrationUI() {
      speechPlaying = false;
      if (narrBtn) narrBtn.textContent = '▶';
      updateTabPulse();
    }

    function ensureNarration() {
      if (narrationAudio) return narrationAudio;
      const audio = new Audio(narrationSrc);
      const saved = localStorage.getItem('archive_narration_vol');
      const sv = saved ? parseInt(saved) : 50;
      narrationAudio = audio;
      narrationGain = wireGain(audio);
      applyNarrationVolume(sv);
      if (narrVol) narrVol.value = String(sv);

      audio.addEventListener('ended', () => {
        resetNarrationUI();
        W.__archiveClearSpeech(audio);
      });

      audio.addEventListener('error', () => {
        resetNarrationUI();
        if (narrBtn) {
          narrBtn.textContent = '×';
          narrBtn.disabled = true;
        }
        W.__archiveClearSpeech(audio);
      });

      return audio;
    }

    if (narrationSrc && narrBtn) {
      narrBtn.addEventListener('click', () => {
        const audio = ensureNarration();
        if (speechPlaying && W.__archiveAudio.speech === audio) {
          // Pause this narration
          audio.pause();
          resetNarrationUI();
          W.__archiveClearSpeech(audio);
        } else {
          // Claim the speech slot. This pauses inline audio or other speech.
          W.__archiveSetSpeech(audio, resetNarrationUI);
          audio.play().then(() => {
            speechPlaying = true;
            narrBtn.textContent = '⏸';
            updateTabPulse();
          }).catch(() => { /* ignore */ });
        }
      });
    }

    narrVol?.addEventListener('input', () => {
      const v = parseInt(narrVol.value);
      applyNarrationVolume(v);
      localStorage.setItem('archive_narration_vol', String(v));
    });

    if (narrationSrc && narrBtn && !reducedMotion) {
      setTimeout(() => {
        if (!speechPlaying) {
          const audio = ensureNarration();
          W.__archiveSetSpeech(audio, resetNarrationUI);
          audio.play().then(() => {
            speechPlaying = true;
            narrBtn.textContent = '⏸';
            updateTabPulse();
          }).catch(() => {});
        }
      }, 2000);
    }
  });
</script>

<style>
  .audio-panel {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    z-index: 90;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    font-family: var(--font-mono), monospace;
  }

  .audio-panel-tab {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream, #f5f1e8);
    border: 1px solid var(--color-rule, #c9c2af);
    cursor: pointer;
    font-size: 1rem;
    opacity: 0.5;
    transition: opacity 150ms ease;
  }

  .audio-panel-tab:hover {
    opacity: 0.85;
  }

  .audio-panel-tab.is-playing {
    opacity: 0.75;
    animation: tab-pulse 2s ease-in-out infinite;
  }

  @keyframes tab-pulse {
    0%, 100% { opacity: 0.75; }
    50% { opacity: 0.45; }
  }

  .audio-panel-drawer {
    display: none;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--color-cream, #f5f1e8);
    border: 1px solid var(--color-rule, #c9c2af);
    padding: 0.75rem 1rem;
    min-width: 13rem;
  }

  .audio-panel.is-open .audio-panel-drawer {
    display: flex;
  }

  .audio-control {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .audio-control-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .audio-btn {
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-rule, #c9c2af);
    cursor: pointer;
    font-size: 0.7rem;
    color: inherit;
    padding: 0;
    line-height: 1;
  }

  .audio-btn:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .audio-control-label {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    opacity: 0.65;
  }

  .audio-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    background: var(--color-rule, #c9c2af);
    outline: none;
    cursor: pointer;
    margin: 0.15rem 0;
  }

  .audio-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-ink, #1a1a1a);
    border: none;
    cursor: pointer;
  }

  .audio-slider::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-ink, #1a1a1a);
    border: none;
    cursor: pointer;
  }

  @media (prefers-color-scheme: dark) {
    .audio-panel-tab {
      background: var(--color-cream-dark, #0e0d0b);
      border-color: var(--color-rule-dark, #2a2622);
    }
    .audio-panel-drawer {
      background: var(--color-cream-dark, #0e0d0b);
      border-color: var(--color-rule-dark, #2a2622);
    }
    .audio-btn {
      border-color: var(--color-rule-dark, #2a2622);
    }
    .audio-btn:hover {
      background: rgba(255, 255, 255, 0.05);
    }
    .audio-slider {
      background: var(--color-rule-dark, #2a2622);
    }
    .audio-slider::-webkit-slider-thumb {
      background: var(--color-ink-dark, #e8e2d3);
      border-radius: 50%;
    }
    .audio-slider::-moz-range-thumb {
      background: var(--color-ink-dark, #e8e2d3);
      border-radius: 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .audio-panel-tab.is-playing {
      animation: none;
    }
  }
</style>
