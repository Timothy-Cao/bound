---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import ConstructionBanner from '../components/ConstructionBanner.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'A recovered archive.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 16 16%22><rect width=%2216%22 height=%2216%22 fill=%22%23000%22/></svg>" />
    <title>{title}</title>
    <ClientRouter fallback="swap" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <main id="main-content" class="page" tabindex="-1">
      <slot />
    </main>

    <ConstructionBanner />

    <nav class="legal-links" aria-label="Legal links">
      <a href="/privacy">Privacy</a>
      <a href="mailto:timcao.support@gmail.com">Contact</a>
    </nav>

    <style>
      .page {
        max-width: 44rem;
        margin: 0 auto;
        padding: 3rem 1.5rem 4rem;
      }
      .page:focus {
        outline: none;
      }
      @media (min-width: 768px) {
        .page {
          padding: 5rem 2rem 6rem;
        }
      }
      .legal-links {
        position: fixed;
        right: 0.75rem;
        bottom: 0.5rem;
        z-index: 20;
        display: flex;
        gap: 0.5rem;
        padding: 0.25rem 0.5rem;
        border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
        background: color-mix(in srgb, Canvas 82%, transparent);
        font-size: 0.68rem;
        opacity: 0.72;
        backdrop-filter: blur(8px);
      }
      .legal-links a {
        color: inherit;
      }
    </style>

    {/* Persistent audio coordination: music singleton + speech singleton.
        Attached once at document level so it survives view transitions.
        Music and speech can overlap each other; never with their own kind. */}
    <script>
      (() => {
        const W = window as any;
        if (W.__archiveAudioInit) return;
        W.__archiveAudioInit = true;

        // Audio state singletons.
        // music slot: ambient background music (BackgroundMusic component)
        // speech slot: narration AND inline audio artifacts share this slot
        W.__archiveAudio = {
          music: null as HTMLAudioElement | null,
          musicOnStop: null as (() => void) | null,
          speech: null as HTMLAudioElement | null,
          speechOnStop: null as (() => void) | null,
        };

        // Music coordinator: takes ownership of the music slot, kills previous music
        // (but never speech). Components register a cleanup callback for UI reset.
        W.__archiveSetMusic = function (audio: HTMLAudioElement, onStop: () => void) {
          const prev = W.__archiveAudio.music;
          if (prev && prev !== audio) {
            try { prev.pause(); } catch (e) { /* ignore */ }
            try { prev.src = ''; } catch (e) { /* ignore */ }
            const prevOnStop = W.__archiveAudio.musicOnStop;
            if (prevOnStop) { try { prevOnStop(); } catch (e) { /* ignore */ } }
          }
          W.__archiveAudio.music = audio;
          W.__archiveAudio.musicOnStop = onStop;
        };
        W.__archiveClearMusic = function (audio: HTMLAudioElement) {
          if (W.__archiveAudio.music === audio) {
            W.__archiveAudio.music = null;
            W.__archiveAudio.musicOnStop = null;
          }
        };

        // Speech coordinator: takes ownership of the speech slot, kills previous speech
        // (narration or inline artifact). Never touches music.
        W.__archiveSetSpeech = function (audio: HTMLAudioElement, onStop: () => void) {
          const prev = W.__archiveAudio.speech;
          if (prev && prev !== audio) {
            try { prev.pause(); } catch (e) { /* ignore */ }
            const prevOnStop = W.__archiveAudio.speechOnStop;
            if (prevOnStop) { try { prevOnStop(); } catch (e) { /* ignore */ } }
          }
          W.__archiveAudio.speech = audio;
          W.__archiveAudio.speechOnStop = onStop;
        };
        W.__archiveClearSpeech = function (audio: HTMLAudioElement) {
          if (W.__archiveAudio.speech === audio) {
            W.__archiveAudio.speech = null;
            W.__archiveAudio.speechOnStop = null;
          }
        };

        // Inline audio artifact click handler.
        // Each .audio-play button has its own HTMLAudioElement attached lazily.
        // Playing one inline artifact kills the speech slot (other inline + narration).
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement | null;
          if (!target || !target.classList.contains('audio-play')) return;

          const btn = target as HTMLButtonElement & { _audio?: HTMLAudioElement };
          const src = btn.getAttribute('data-src');
          if (!src) return;

          const resetUI = () => {
            btn.textContent = '▶';
            btn.setAttribute('aria-label', btn.getAttribute('data-label-play') || 'Play');
          };

          if (!btn._audio) {
            const audio = new Audio(src);
            audio.addEventListener('ended', () => {
              resetUI();
              W.__archiveClearSpeech(audio);
            });
            audio.addEventListener('error', () => {
              btn.textContent = '×';
              btn.disabled = true;
              btn.setAttribute('aria-label', 'Audio unavailable');
              W.__archiveClearSpeech(audio);
            });
            btn._audio = audio;
          }

          if (btn._audio.paused) {
            // Become the speech singleton; this will pause any other speech.
            W.__archiveSetSpeech(btn._audio, resetUI);
            btn._audio.currentTime = 0;
            btn._audio.play().catch(() => { /* ignore */ });
            btn.textContent = '■';
            btn.setAttribute('aria-label', btn.getAttribute('data-label-pause') || 'Pause');
          } else {
            btn._audio.pause();
            resetUI();
            W.__archiveClearSpeech(btn._audio);
          }
        });

        // Pause inline audio when navigating away (view transitions).
        // Music and speech in the global slots are handled by their owners.
        document.addEventListener('astro:before-swap', () => {
          document.querySelectorAll<HTMLButtonElement>('.audio-play').forEach((btn) => {
            const b = btn as HTMLButtonElement & { _audio?: HTMLAudioElement };
            if (b._audio && !b._audio.paused) {
              b._audio.pause();
            }
          });
        });
      })();
    </script>
  </body>
</html>
